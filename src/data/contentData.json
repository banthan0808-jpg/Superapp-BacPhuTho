  "faqGuides": [
    {
      "id": "1",
      "title": "Hướng dẫn quên mật khẩu Ipay",
      "videoUrl": "https://www.youtube.com/watch?v=86r0pxPOzbs",
      "steps": [
        {
          "step": 1,
          "text": "Ở màn hình đăng nhập, chọn Quên mật khẩu.",
          "imageUrl": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.1.png"
        },
        {
          "step": 2,
          "text": "Nhập tên đăng nhập và số điện thoại đăng ký sau đó bấm “Tiếp tục”",
          "imageUrl": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.2.png"
        },
        {
          "step": 3,
          "text": "Nhập mã OTP được gửi về tin nhắn SMS, sau đó bấm Tiếp tục",
          "imageUrl": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.3.png"
        },
        {
          "step": 4,
          "text": "Xác thực khuôn mặt theo yêu cầu. Sau khi hoàn thành Ipay sẽ gửi mật khẩu mới về tin nhắn (SMS). Bấm đăng nhập Ipay để tiếp tục",
          "imageUrl": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.4.png"
        },
        {
          "step": 5,
          "text": "Nhập mật khẩu theo yêu cầu. Mật khẩu hiện tại: Nhập theo mật khẩu được gửi về tin nhắn (SMS). Mật khẩu mới: Là mật khẩu mà khách hàng cần đổi. Bấm Tiếp tục",
          "imageUrl": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.5.png"
        },
        {
          "step": 6,
          "text": "Thực hiện quét khuôn mặt để xác nhận đổi mật khẩu thành công",
          "imageUrl": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.6.png"
        }
      ]
    },
    {
      "id": "2",
